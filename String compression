s="ABBCCCDDDDEEEEE"
a=[]
pos=0
for i in range(len(s)):
    count=1
    for j in range(pos,len(s)):
        prev=s[j]
        if j+1<len(s) and s[j+1]==prev:
            count+=1
        else:
            a.append(prev)
            a.append(count)
            pos=j+1
            break
res=''.join( str(i) for i in a)
print(res)
