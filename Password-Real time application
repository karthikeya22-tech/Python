a=input("Enter your password:")
up=0
dg=0
sp=0
sm=0
if len(a)>=7:
    for i in a:
        if i.isupper():
            up+=1
        elif i.islower():
            sm+=1
        elif i.isdigit():
            dg+=1
        else:
            sp+=1
    if up>0 and sm>0 and sp>0 and dg>0:
        print("Strong Password")
    else:
        print("Weak Password")
else:
    print("Password must contain minimum 7 characters")
